# Dill Bot Environment Variables
# Copy this file to .env and fill in your actual values

# Slack App Configuration
# Get these from your Slack App settings at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Persistent Storage Configuration (Optional)
# Create a private Slack channel and invite your bot to it
# Then add the channel ID here for automatic database backups
DILL_STORAGE_CHANNEL_ID=C1234567890

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=INFO

# Performance Settings (Optional - defaults are usually fine)
# RATE_LIMIT_WINDOW=5000
# RATE_LIMIT_MAX_ACTIONS=3
# ANALYTICS_RETENTION_DAYS=90
# DEFAULT_TIMEOUT_MINUTES=180
# MAX_TIMEOUT_MINUTES=1440
# MIN_TIMEOUT_MINUTES=1

# --- Optional: Encryption key for backup data (64 hex chars for AES-256) ---
# If set, backups sent to Slack will be encrypted. Leave blank for plaintext.
DILL_BACKUP_ENCRYPTION_KEY=